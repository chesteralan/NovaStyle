{
  "manifest_version": 3,
  "name": "NovaStyle",
  "version": "1.3.3",
  "description": "Visually edit any webpage's CSS — spacing, typography, colors, and layout.",
  "browser_specific_settings": {
    "gecko": {
      "id": "novastyle@example.com",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["assets/service-worker.js"],
    "service_worker": "assets/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["assets/panel.js", "assets/panel.css"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "NovaStyle",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
